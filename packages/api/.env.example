# Servidor
PORT=3001
# NODE_ENV=development

# Banco — usado por Drizzle e runtime (postgres://...)
DATABASE_URL=postgresql://user:password@localhost:5432/shopai

# Opcional: montar DATABASE_URL manualmente (não lido diretamente pelo código)
# DB_USER=
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=

# JWT (use um segredo longo em produção)
JWT_SECRET=

# Google Sign-In — validação do token no backend (Client ID OAuth Web)
GOOGLE_CLIENT_ID=

# Chat / IA — OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
