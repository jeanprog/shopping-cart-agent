{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "seed": "tsx --env-file=.env src/db/seed.ts",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:sync": "drizzle-kit push --force",
    "db:apply-columns": "tsx --env-file=.env scripts/apply-product-columns.ts",
    "db:apply-users-oauth": "tsx --env-file=.env scripts/apply-users-google-columns.ts",
    "db:apply-onboarding-schema": "tsx --env-file=.env scripts/apply-onboarding-schema.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "agno": "^1.0.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "shopai-monorepo": "file:../..",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
